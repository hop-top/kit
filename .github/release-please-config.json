{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": true,
  "pull-request-title-pattern": "chore(release):${component} ${version}",
  "include-component-in-tag": true,
  "tag-separator": "/",
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "perf",
      "section": "Performance"
    },
    {
      "type": "refactor",
      "section": "Refactoring",
      "hidden": true
    },
    {
      "type": "chore",
      "section": "Miscellaneous",
      "hidden": true
    },
    {
      "type": "docs",
      "section": "Documentation",
      "hidden": true
    },
    {
      "type": "test",
      "section": "Tests",
      "hidden": true
    },
    {
      "type": "ci",
      "section": "CI",
      "hidden": true
    },
    {
      "type": "build",
      "section": "Build",
      "hidden": true
    }
  ],
  "linked-versions": [
    {
      "group": "kit",
      "components": ["kit", "sdk/ts", "sdk/py"]
    }
  ],
  "packages": {
    ".": {
      "release-type": "go",
      "component": "kit",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "exclude-paths": [
        "sdk/ts",
        "sdk/py",
        "templates",
        "incubator"
      ],
      "prerelease": true,
      "prerelease-type": "alpha"
    },
    "sdk/ts": {
      "release-type": "node",
      "component": "sdk/ts",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "prerelease": true,
      "prerelease-type": "alpha"
    },
    "sdk/py": {
      "release-type": "python",
      "component": "sdk/py",
      "package-name": "hop-top-kit",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "extra-files": [
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.project.version"
        }
      ],
      "prerelease": true,
      "prerelease-type": "alpha"
    },
    "incubator/qmochi": {
      "release-type": "go",
      "component": "qmochi",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "prerelease": true,
      "prerelease-type": "alpha"
    },
    "incubator/ash": {
      "release-type": "go",
      "component": "ash",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "prerelease": true,
      "prerelease-type": "alpha"
    },
    "incubator/aim": {
      "release-type": "go",
      "component": "aim",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "prerelease": true,
      "prerelease-type": "alpha"
    }
  }
}
